GROQ_API_KEY=your_groq_api_key_here
# Optional: override default model
# OMNIHEDGE_MODEL=llama-3.3-70b-versatile

# Walrus (testnet, no config needed — uses public endpoints by default)

# World AgentKit + x402 payment gate
# Set PAYMENT_ADDRESS to enable the AgentKit free-trial gate on /api/analyze.
# Human-backed agents (World ID verified via AgentKit) get AGENTKIT_FREE_USES free calls.
# Unverified callers pay AGENTKIT_PRICE USDC per call on Base Sepolia.
# Leave unset to run in open demo mode (no payment required).
# PAYMENT_ADDRESS=0xYourWalletAddress
# AGENTKIT_FREE_USES=3
# AGENTKIT_PRICE=$0.02
# AGENTKIT_NETWORK=eip155:84532
